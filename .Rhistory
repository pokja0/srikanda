title = "",
lineStyle = list(color = "gray", type = "dashed", width = 2)
) |>
# Menambahkan garis horizontal di 50
e_mark_line(
data = list(yAxis = median_skor),
title = "",
lineStyle = list(color = "gray", type = "dashed", width = 2)
) |>
e_tooltip(
trigger = "item",
formatter = htmlwidgets::JS("
function(params){
return(
'<b>' + params.name + '</b><br/>' +
'Persen Baca: ' + params.value[0] + '<br/>' +
'Persen Tindaklanjut: ' + params.value[1]
)
}
")
) |>
e_title("Scatter Plot 4 Kuadran", "Persen Baca vs Persen Tindaklanjut (batas 50%)") |>
e_legend(show = T) |>  # Legend dimatikan dulu karena grouping bermasalah
e_grid(containLabel = TRUE, left = "15%", right = "10%")
runApp('app_bslib.R')
View(df_final_srikandi)
