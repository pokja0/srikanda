# 2. Membuat tabel gt
tabel_paparan <- data_gizi %>%
gt() %>%
# Header & Sub-header
tab_header(
title = md("**Status Gizi Balita per Kabupaten**"),
subtitle = "Data Analisis Anomali Gizi dan Capaian ASI Eksklusif"
) %>%
# Memberi nama kolom yang lebih bersih
cols_label(
Stunting = html("Stunting<br>(%)"),
Wasting = html("Wasting<br>(%)"),
Overweight = html("Overweight<br>(%)"),
Underweight = html("Underweight<br>(%)"),
ASI_Eksklusif = html("ASI<br>Eksklusif (%)"),
Catatan_Anomali = "Catatan Anomali Utama"
) %>%
# Format angka desimal
fmt_number(columns = 2:6, decimals = 2) %>%
# Styling Baris Provinsi (paling bawah)
tab_style(
style = list(
cell_fill(color = "lightgrey"),
cell_text(weight = "bold")
),
locations = cells_body(rows = Kabupaten == "PROVINSI")
) %>%
# Menonjolkan angka anomali (Bold sesuai gambar)
tab_style(
style = cell_text(weight = "bold", color = "darkred"),
locations = list(
cells_body(columns = Stunting, rows = c(1, 3, 6)),
cells_body(columns = Wasting, rows = c(3, 5)),
cells_body(columns = Underweight, rows = c(1, 3)),
cells_body(columns = ASI_Eksklusif, rows = c(1, 5)),
cells_body(columns = Overweight, rows = 7)
)
) %>%
# Pengaturan font dan garis
opt_table_font(font = "Arial") %>%
tab_options(
table.width = px(800),
column_labels.background.color = "#2c3e50",
column_labels.font.weight = "bold",
column_labels.font.size = px(14),
heading.title.font.size = px(22),
table.border.top.color = "black",
table.border.bottom.color = "black"
) %>%
# Membuat teks catatan lebih kecil agar pas di slide
cols_width(
Catatan_Anomali ~ px(300),
Kabupaten ~ px(150),
Stunting ~ px(80),
Overweight ~ px(80),
Underweight ~ px(80),
ASI_Eksklusif ~ px(80)
) %>%
tab_style(
style = cell_text(size = px(12), style = "italic"),
locations = cells_body(columns = Catatan_Anomali)
)
